# SimGuard environment variables

# Demo integration strategy: AUTO | SIMULATION | LIVE
INTEGRATION_MODE=SIMULATION

# Nokia Network as Code (CAMARA APIs)
NAC_API_KEY=your-rapidapi-key-here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database
DATABASE_URL=sqlite:///./simguard.db

# Application
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# Nokia Number Verification OAuth endpoints
NAC_AUTH_CLIENTCREDENTIALS_URL=https://nac-authorization-server.p-eu.rapidapi.com
NAC_AUTH_CLIENTCREDENTIALS_HOST=nac-authorization-server.nokia.rapidapi.com
NAC_WELLKNOWN_METADATA_URL=https://well-known-metadata.p-eu.rapidapi.com
NAC_WELLKNOWN_METADATA_HOST=well-known-metadata.nokia.rapidapi.com
NAC_NUMBER_VERIFICATION_URL=https://number-verification.p-eu.rapidapi.com
NAC_NUMBER_VERIFICATION_HOST=number-verification.nokia.rapidapi.com

# Max payload size in bytes
MAX_PAYLOAD_SIZE=1048576
